# .env.example - Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env file with real credentials to version control

# =============================================================================
# SUPABASE DATABASE CONFIGURATION
# =============================================================================
# Get this from: Supabase Dashboard > Settings > Database
# Format: postgresql://postgres:[password]@[host]:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres

# Database connection settings
DATABASE_POOL_SIZE=5
DATABASE_POOL_RECYCLE=3600
DATABASE_ECHO=false
DATABASE_POOL_PRE_PING=true
DATABASE_CONNECT_TIMEOUT=30

# =============================================================================
# GOOGLE OAUTH CONFIGURATION
# =============================================================================
# Get these from: Google Cloud Console > APIs & Credentials > OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-oauth-client-secret

# OAuth redirect URI (update after deployment)
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# Google Drive API settings
GOOGLE_DRIVE_SCOPES=https://www.googleapis.com/auth/drive.file
GOOGLE_VISION_ENABLED=true
GOOGLE_VISION_MONTHLY_LIMIT=950
GOOGLE_API_REQUESTS_PER_MINUTE=100
GOOGLE_API_REQUESTS_PER_DAY=10000

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECURITY_SECRET_KEY=your-generated-jwt-secret-key-change-in-production

# JWT token settings
SECURITY_ALGORITHM=HS256
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=30
SECURITY_REFRESH_TOKEN_EXPIRE_DAYS=7

# Password requirements
SECURITY_PASSWORD_MIN_LENGTH=12
SECURITY_PASSWORD_REQUIRE_UPPERCASE=true
SECURITY_PASSWORD_REQUIRE_LOWERCASE=true
SECURITY_PASSWORD_REQUIRE_NUMBERS=true
SECURITY_PASSWORD_REQUIRE_SYMBOLS=true

# Session security
SECURITY_SESSION_COOKIE_SECURE=true
SECURITY_SESSION_COOKIE_HTTPONLY=true
SECURITY_SESSION_COOKIE_SAMESITE=lax

# Rate limiting
SECURITY_RATE_LIMIT_REQUESTS_PER_MINUTE=60
SECURITY_RATE_LIMIT_BURST_SIZE=10

# reCAPTCHA (optional)
SECURITY_RECAPTCHA_ENABLED=false
SECURITY_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
SECURITY_RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================
# Application identification
APP_NAME=Bonifatus DMS
APP_VERSION=1.0.0
APP_DESCRIPTION=Professional Document Management System

# Environment (development, staging, production)
APP_ENVIRONMENT=development
APP_DEBUG=true
APP_TESTING=false

# API configuration
APP_API_PREFIX=/api/v1
APP_DOCS_URL=/api/docs
APP_REDOC_URL=/api/redoc

# CORS settings (comma-separated list)
APP_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
APP_CORS_ALLOW_CREDENTIALS=true
APP_CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
APP_CORS_ALLOW_HEADERS=*

# File processing
APP_MAX_FILE_SIZE_MB=50
APP_ALLOWED_FILE_TYPES=.pdf,.doc,.docx,.txt,.jpg,.jpeg,.png,.tiff,.bmp

# Logging
APP_LOG_LEVEL=INFO
APP_LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# =============================================================================
# GOOGLE CLOUD PLATFORM CONFIGURATION
# =============================================================================
# Get this from: Google Cloud Console > IAM & Admin > Projects
GCP_PROJECT=your-gcp-project-id

# Service account key (for deployment)
# Generate from: Google Cloud Console > IAM & Admin > Service Accounts
GCP_SA_KEY=your-service-account-key-json-content

# Cloud Run settings
GCP_REGION=us-central1
GCP_SERVICE_NAME=bonifatus-dms-api

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
# Development server
PORT=8000
HOST=0.0.0.0

# Development database (alternative to Supabase for local testing)
DEV_DATABASE_URL=postgresql://bonifatus:bonifatus_dev_password@localhost:5432/bonifatus_dms

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================
# Production domain (update after deployment)
PRODUCTION_DOMAIN=your-app-domain.run.app

# SSL/TLS settings
PRODUCTION_SSL_REDIRECT=true
PRODUCTION_SECURE_HEADERS=true

# Monitoring and analytics
PRODUCTION_ERROR_REPORTING=true
PRODUCTION_PERFORMANCE_MONITORING=true
PRODUCTION_ANALYTICS_ENABLED=true

# =============================================================================
# TIER LIMITS CONFIGURATION
# =============================================================================
# Free tier limits
FREE_TIER_DOCUMENT_LIMIT=100
FREE_TIER_MONTHLY_UPLOADS=50
FREE_TIER_MAX_FILE_SIZE_MB=50
FREE_TIER_CUSTOM_CATEGORIES=10

# Premium trial limits
PREMIUM_TRIAL_DOCUMENT_LIMIT=500
PREMIUM_TRIAL_MONTHLY_UPLOADS=200
PREMIUM_TRIAL_MAX_FILE_SIZE_MB=100
PREMIUM_TRIAL_CUSTOM_CATEGORIES=25

# Premium limits
PREMIUM_DOCUMENT_LIMIT=0
PREMIUM_MONTHLY_UPLOADS=0
PREMIUM_MAX_FILE_SIZE_MB=200
PREMIUM_CUSTOM_CATEGORIES=100

# Processing limits
MAX_CONCURRENT_PROCESSING=5
OCR_MONTHLY_LIMIT=1000
AI_PROCESSING_MONTHLY_LIMIT=500

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# AI and processing features
FEATURE_OCR_ENABLED=true
FEATURE_AI_CATEGORIZATION_ENABLED=true
FEATURE_GOOGLE_DRIVE_ENABLED=true

# User management
FEATURE_USER_REGISTRATION_ENABLED=true
FEATURE_PREMIUM_TRIAL_ENABLED=true

# System features
FEATURE_MAINTENANCE_MODE=false
FEATURE_DATABASE_BACKUP_ENABLED=true
FEATURE_ERROR_REPORTING_ENABLED=true

# =============================================================================
# LOCALIZATION
# =============================================================================
# Default language
DEFAULT_LANGUAGE=en

# Supported languages (comma-separated)
SUPPORTED_LANGUAGES=en,de

# =============================================================================
# OPTIONAL INTEGRATIONS
# =============================================================================
# Email service (for notifications)
EMAIL_SERVICE_ENABLED=false
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASSWORD=your-app-password

# Monitoring services
SENTRY_DSN=your-sentry-dsn-url
DATADOG_API_KEY=your-datadog-api-key

# Analytics
GOOGLE_ANALYTICS_ID=your-ga-tracking-id

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# Override any setting for development
# These will be ignored in production

# Local database for development
# DEV_DATABASE_URL=sqlite:///./dev_bonifatus.db

# Local file storage (instead of Google Drive)
# DEV_USE_LOCAL_STORAGE=true
# DEV_STORAGE_PATH=./dev_storage

# Disable external services for development
# DEV_DISABLE_GOOGLE_APIS=true
# DEV_DISABLE_EMAIL=true

# =============================================================================
# INSTRUCTIONS FOR SETUP
# =============================================================================
# 1. Copy this file to .env: cp .env.example .env
# 2. Update DATABASE_URL with your Supabase connection string
# 3. Update GOOGLE_CLIENT_ID and GOOGLE_CLIENT_SECRET from Google Cloud Console
# 4. Generate SECURITY_SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 5. Update GCP_PROJECT with your Google Cloud project ID
# 6. For production deployment, add these as GitHub Secrets
# 7. Never commit the .env file to version control!